+def test_prompt_tail_cache_probes_deepest_matching_boundary():
+    block_size = 64
+    kv_cache_config = _make_hybrid_kv_cache_config(
+        block_size, 32, ["full", "mamba_align"]
+    )
+    manager = KVCacheManager(
+        kv_cache_config,
+        max_model_len=8192,
+        enable_caching=True,
+        hash_block_size=block_size,
+    )
+
+    req0_token_ids = list(range(84))
+    req0 = make_request(
+        "prompt_tail_0",
+        req0_token_ids,
+        block_size,
+        sha256,
+        cache_salt="conversation-0",
+        prompt_tail_cache_stable_len=80,
+    )
+    computed_blocks, num_computed_tokens = manager.get_computed_blocks(req0)
+    assert num_computed_tokens == 0
+
+    blocks = manager.allocate_slots(
+        req0,
+        80,
+        num_computed_tokens,
+        computed_blocks,
+    )
+    assert blocks is not None
+
+    copies = manager.take_mamba_prompt_cache_copies()
+    assert len(copies) == 1
+    assert copies[0].src_block_idx == 1
+    manager.release_mamba_prompt_cache_copies(copies)
+    assert manager.take_kv_cache_block_copy_ops() == []
+
+    manager.free(req0)
+
+    req1_token_ids = req0_token_ids + list(range(84, 124))
+    req1 = make_request(
+        "prompt_tail_1",
+        req1_token_ids,
+        block_size,
+        sha256,
+        cache_salt="conversation-0",
+        prompt_tail_cache_stable_len=120,
+    )
+    computed_blocks, num_computed_tokens = manager.get_computed_blocks(req1)
+    assert num_computed_tokens == 80
+    assert len(computed_blocks.blocks[0]) == 0
+    assert [block.is_null for block in computed_blocks.blocks[1]] == [True]
+
+    blocks = manager.allocate_slots(
+        req1,
+        32,
+        num_computed_tokens,
+        computed_blocks,
+    )
+    assert blocks is not None
+
+    copy_ops = manager.take_kv_cache_block_copy_ops()
+    assert len(copy_ops) == 1
+    assert copy_ops[0].kv_cache_group_id == 0
+    assert copy_ops[0].num_tokens == 16
+
+    restores = manager.take_mamba_prompt_cache_restores()
+    assert len(restores) == 1
+    assert restores[0].dst_block_idx == 1
+    manager.release_mamba_prompt_cache_restores(restores)
+
+    copies = manager.take_mamba_prompt_cache_copies()
+    assert len(copies) == 1
+    assert copies[0].src_block_idx == 1
+    manager.release_mamba_prompt_cache_copies(copies)
+    manager.free(req1)
+
+
