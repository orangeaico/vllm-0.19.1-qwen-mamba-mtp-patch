@@ -0,0 +1,25 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+
+from vllm.config import SpeculativeConfig
+
+
+def _spec_config_for_method(method: str) -> SpeculativeConfig:
+    config = object.__new__(SpeculativeConfig)
+    config.method = method
+    return config
+
+
+def test_mtp_does_not_enable_eagle_prefix_cache_behaviors():
+    mtp_config = _spec_config_for_method("mtp")
+    eagle_config = _spec_config_for_method("eagle")
+    eagle3_config = _spec_config_for_method("eagle3")
+
+    assert mtp_config.use_eagle()
+    assert not mtp_config.use_eagle_prefix_cache_drop()
+    assert not mtp_config.use_kv_cache_lookahead()
+
+    assert eagle_config.use_eagle_prefix_cache_drop()
+    assert eagle_config.use_kv_cache_lookahead()
+    assert eagle3_config.use_eagle_prefix_cache_drop()
+    assert eagle3_config.use_kv_cache_lookahead()
