+        ),
+        max_model_len=8192,
+        enable_caching=True,
+        hash_block_size=hash_block_size,
+        enable_partial_attn_cache=True,
+    )
+    mamba_manager = manager.coordinator.single_type_managers[1]
+
+    req = make_request("0", list(range(160)), hash_block_size, sha256)
+    computed_blocks, num_computed_tokens = manager.get_computed_blocks(req)
+    assert num_computed_tokens == 0
+
+    def allocate(num_tokens: int, blocks=manager.empty_kv_cache_blocks):
+        allocated = manager.allocate_slots(
+            req,
+            num_tokens,
+            0,
+            blocks,
+        )
+        assert allocated is not None
+        mamba_source_block_refs = manager.take_mamba_source_block_refs()
+        req.num_computed_tokens += num_tokens
+        manager.release_mamba_source_block_refs(mamba_source_block_refs)
+        manager.new_step_starts()
+
+    allocate(64, computed_blocks)
+    allocate(64)
+    allocate(16)
+    allocate(16)
+
+    mamba_blocks = mamba_manager.req_to_blocks[req.request_id]
+    non_null_mamba_indices = [
+        idx for idx, block in enumerate(mamba_blocks) if not block.is_null
+    ]
+    assert len(non_null_mamba_indices) <= 2
+
+    latest_key = make_block_hash_with_group_id(req.block_hashes[9], 1)
+    coarse_key = make_block_hash_with_group_id(req.block_hashes[7], 1)
+    assert manager.block_pool.cached_block_hash_to_block.get_one_block(
+        latest_key
+    ) is None
+    assert manager.block_pool.cached_block_hash_to_block.get_one_block(
+        coarse_key
+    ) is None
+
+    manager.free(req)
+
+    assert manager.block_pool.cached_block_hash_to_block.get_one_block(
+        latest_key
+    ) is not None
+    assert manager.block_pool.cached_block_hash_to_block.get_one_block(
+        coarse_key
+    ) is None
+
