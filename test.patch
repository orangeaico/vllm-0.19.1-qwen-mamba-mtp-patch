+@pytest.mark.parametrize("scheduler_cls", [Scheduler, AsyncScheduler])
+def test_hybrid_latest_caches_completed_prompt_boundary_for_next_turn(
+    scheduler_cls: type[Scheduler],
+):
+    mamba_block_size = 16
+    num_prompt_tokens = 1413
+    num_output_tokens = 200
+    num_next_user_tokens = 400
+    scheduler = _make_hybrid_latest_scheduler(scheduler_cls=scheduler_cls)
+
+    def make_model_runner_output(
+        scheduler_output: SchedulerOutput,
+    ) -> ModelRunnerOutput:
+        req_ids = list(scheduler_output.num_scheduled_tokens)
+        sampled_token_ids: list[list[int]] = []
+        for req_id in req_ids:
+            request = scheduler.requests.get(req_id)
+            token_id = 1000 + (request.num_output_tokens if request else 0)
+            sampled_token_ids.append(
+                [] if request is not None and request.is_prefill_chunk else [token_id]
+            )
+        return ModelRunnerOutput(
+            req_ids=req_ids,
+            req_id_to_index={req_id: i for i, req_id in enumerate(req_ids)},
+            sampled_token_ids=sampled_token_ids,
+            logprobs=None,
+            prompt_logprobs_dict={},
+            pooler_output=[],
+        )
+
+    (req0,) = create_requests(
+        num_requests=1,
+        num_tokens=num_prompt_tokens,
+        max_tokens=num_output_tokens,
+        same_prompt=True,
+        block_size=mamba_block_size,
+        req_ids=["0"],
+    )
+    scheduler.add_request(req0)
+
+    pending_outputs: list[SchedulerOutput] = []
+    for _ in range(2):
+        output = scheduler.schedule()
+        if output.num_scheduled_tokens:
+            pending_outputs.append(output)
+
+    num_steps = 0
+    while pending_outputs:
+        output = pending_outputs.pop(0)
+        scheduler.update_from_output(output, make_model_runner_output(output))
+        output = scheduler.schedule()
+        if output.num_scheduled_tokens:
+            pending_outputs.append(output)
+        num_steps += 1
+        assert num_steps < 512
+
+    assert scheduler.get_num_unfinished_requests() == 0
+    assert req0.num_output_tokens == num_output_tokens
+
+    next_prompt_token_ids = (
+        list(req0.prompt_token_ids)
+        + list(req0.output_token_ids)
+        + list(range(2000, 2000 + num_next_user_tokens))
+    )
+    (req1,) = create_requests(
+        num_requests=1,
+        num_tokens=len(next_prompt_token_ids),
+        max_tokens=1,
+        same_prompt=True,
+        block_size=mamba_block_size,
+        req_ids=["1"],
+    )
+    req1.prompt_token_ids = next_prompt_token_ids
+    req1._all_token_ids = req1.prompt_token_ids.copy()
+    req1.all_token_ids = ConstantList(req1._all_token_ids)
+    req1.block_hashes = []
+    req1.update_block_hashes()
+
+    scheduler.add_request(req1)
+    output = scheduler.schedule()
+
+    # Live serving updates the cross-request prefix cache at prompt-prefill
+    # boundaries. Decoded tokens become reusable after they are included in a
+    # later request prompt, so req1 should at least reuse req0's completed
+    # prompt boundary and recompute the assistant output plus new user tail.
+    expected_reusable_tokens = (
+        num_prompt_tokens // mamba_block_size
+    ) * mamba_block_size
+    assert req1.num_cached_tokens >= expected_reusable_tokens
+    assert (
+        output.num_scheduled_tokens[req1.request_id]
+        <= req1.num_prompt_tokens - expected_reusable_tokens
+    )
+
+    pending_outputs = [output]
+    num_steps = 0
+    while pending_outputs:
+        output = pending_outputs.pop(0)
+        scheduler.update_from_output(output, make_model_runner_output(output))
+        output = scheduler.schedule()
+        if output.num_scheduled_tokens:
+            pending_outputs.append(output)
+        num_steps += 1
+        assert num_steps < 512
+
+    assert scheduler.get_num_unfinished_requests() == 0
+
+    (req2,) = create_requests(
+        num_requests=1,
+        num_tokens=len(next_prompt_token_ids),
+        max_tokens=1,
+        same_prompt=True,
+        block_size=mamba_block_size,
+        req_ids=["2"],
+    )
+    req2.prompt_token_ids = next_prompt_token_ids
+    req2._all_token_ids = req2.prompt_token_ids.copy()
+    req2.all_token_ids = ConstantList(req2._all_token_ids)
+    req2.block_hashes = []
+    req2.update_block_hashes()
+
+    scheduler.add_request(req2)
+    output = scheduler.schedule()
+
+    expected_next_prompt_boundary = (
+        len(next_prompt_token_ids) // mamba_block_size
+    ) * mamba_block_size
+    assert req2.num_cached_tokens >= expected_next_prompt_boundary
+    assert (
+        output.num_scheduled_tokens[req2.request_id]
+        <= req2.num_prompt_tokens - expected_next_prompt_boundary
+    )
+
+
