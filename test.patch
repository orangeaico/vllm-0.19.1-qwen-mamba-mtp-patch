+def test_hybrid_latest_mamba_queues_bounded_checkpoints_until_free():
+    hash_block_size = 16
+    manager = KVCacheManager(
+        _make_hybrid_latest_kv_cache_config(
+            attn_block_size=64,
+            mamba_block_size=hash_block_size,
