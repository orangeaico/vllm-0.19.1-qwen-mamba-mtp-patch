+        return self.method in ("eagle", "eagle3")
+
+    def use_kv_cache_lookahead(self) -> bool:
+        """Whether speculative decoding needs KV slots for draft lookahead.
+
+        Eagle-style methods run a draft path that consumes verifier KV slots for
+        lookahead tokens. MTP reuses the target model path, so reserving extra
+        KV slots only increases cache pressure and prefix-cache evictions.
+        """
+        return self.method in ("eagle", "eagle3")
+
